{
  "info": {
    "name": "HelaDry IoT API Collection",
    "description": "Comprehensive Postman collection for testing HelaDry IoT backend API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "firebaseToken",
      "value": "",
      "type": "string",
      "description": "Firebase JWT token for authentication"
    },
    {
      "key": "testDeviceId",
      "value": "test-device-{{randomUUID}}",
      "type": "string"
    },
    {
      "key": "testSessionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is JSON', function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.test('Response contains status field', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.expect(jsonData.status).to.equal('running');",
              "});",
              "",
              "pm.test('Response contains service name', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('service');",
              "    pm.expect(jsonData.service).to.equal('HelaDry Backend');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Device Management",
      "item": [
        {
          "name": "Register Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{testDeviceId}}\",\n  \"device_name\": \"Test Device\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/register",
              "host": ["{{baseUrl}}"],
              "path": ["device", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains device_id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('device_id');",
                  "    pm.expect(jsonData.device_id).to.equal(pm.variables.get('testDeviceId'));",
                  "});",
                  "",
                  "pm.test('Response contains assigned_to_user', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('assigned_to_user');",
                  "});"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a new UUID for each test run",
                  "pm.globals.set('testDeviceId', 'test-device-' + pm.crypto.randomUUID());"
                ]
              }
            }
          ]
        },
        {
          "name": "Start Device Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{testDeviceId}}\",\n  \"temperature\": 45,\n  \"batch_details\": {\n    \"batch_name\": \"Test Batch\",\n    \"duration\": 120,\n    \"material_type\": \"herbs\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/start",
              "host": ["{{baseUrl}}"],
              "path": ["device", "start"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains session details', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('session_id');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData.status).to.equal('started');",
                  "});",
                  "",
                  "// Store session ID for later tests",
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.globals.set('testSessionId', jsonData.session_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Device Temperature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{testDeviceId}}\",\n  \"temperature\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/update-temperature",
              "host": ["{{baseUrl}}"],
              "path": ["device", "update-temperature"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Temperature updated successfully', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('device_id');",
                  "    pm.expect(jsonData).to.have.property('temperature');",
                  "    pm.expect(jsonData.temperature).to.equal(50);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Device Fan Speed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{testDeviceId}}\",\n  \"fan_speed\": 75\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/update-fan-speed",
              "host": ["{{baseUrl}}"],
              "path": ["device", "update-fan-speed"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Fan speed updated successfully', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('device_id');",
                  "    pm.expect(jsonData).to.have.property('fan_speed');",
                  "    pm.expect(jsonData.fan_speed).to.equal(75);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Stop Device Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{testDeviceId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/stop",
              "host": ["{{baseUrl}}"],
              "path": ["device", "stop"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Session stopped successfully', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('device_id');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData.status).to.equal('stopped');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List User Devices",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/device/list",
              "host": ["{{baseUrl}}"],
              "path": ["device", "list"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each device has required properties', function () {",
                  "    const jsonData = pm.response.json();",
                  "    jsonData.forEach(function(device) {",
                  "        pm.expect(device).to.have.property('device_id');",
                  "        pm.expect(device).to.have.property('device_name');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Session Management",
      "item": [
        {
          "name": "Get User Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/session/my-sessions",
              "host": ["{{baseUrl}}"],
              "path": ["session", "my-sessions"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each session has required properties', function () {",
                  "    const jsonData = pm.response.json();",
                  "    jsonData.forEach(function(session) {",
                  "        pm.expect(session).to.have.property('session_id');",
                  "        pm.expect(session).to.have.property('device_id');",
                  "        pm.expect(session).to.have.property('start_time');",
                  "        pm.expect(session).to.have.property('status');",
                  "        pm.expect(session).to.have.property('metrics');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Error Handling Tests",
      "item": [
        {
          "name": "Invalid Temperature Range",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{testDeviceId}}\",\n  \"temperature\": 150\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/update-temperature",
              "host": ["{{baseUrl}}"],
              "path": ["device", "update-temperature"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400 for invalid temperature', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message for invalid temperature', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Missing Authentication",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/device/list",
              "host": ["{{baseUrl}}"],
              "path": ["device", "list"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 401 for missing auth', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid Fan Speed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{testDeviceId}}\",\n  \"fan_speed\": 150\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/update-fan-speed",
              "host": ["{{baseUrl}}"],
              "path": ["device", "update-fan-speed"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400 for invalid fan speed', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message for invalid fan speed', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}