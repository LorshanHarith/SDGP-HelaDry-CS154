              }
            }
          ]
        },
        {
          "name": "Stop Session from Flutter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              },
              {
                "key": "User-Agent",
                "value": "HelaDryApp/{{flutterAppVersion}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"{{flutterTestDeviceId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/stop",
              "host": ["{{baseUrl}}"],
              "path": ["device", "stop"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Session stop from Flutter successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Stop response format for Flutter UI', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('device_id');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData.status).to.equal('stopped');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Flutter App Error Handling",
      "item": [
        {
          "name": "Network Error Simulation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid_token"
              },
              {
                "key": "User-Agent",
                "value": "HelaDryApp/{{flutterAppVersion}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/device/list",
              "host": ["{{baseUrl}}"],
              "path": ["device", "list"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Flutter app handles authentication errors', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});",
                  "",
                  "pm.test('Error response format for Flutter error handling', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "    pm.expect(jsonData.error).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Server Error Handling",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              },
              {
                "key": "User-Agent",
                "value": "HelaDryApp/{{flutterAppVersion}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"nonexistent-device\",\n  \"temperature\": 45\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/device/update-temperature",
              "host": ["{{baseUrl}}"],
              "path": ["device", "update-temperature"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Flutter app handles device not found errors', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
                  "});",
                  "",
                  "pm.test('Error message format for Flutter UI display', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "    pm.expect(jsonData.error).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}